generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH & USERS
// ============================================

enum Role {
  SUPER_ADMIN       // Siège somnOO — vue consolidée tous hôtels
  ADMIN             // GM — accès complet à son hôtel
  OPE_HEBERGEMENT   // DM, réception, gouvernante
  OPE_TECHNIQUE     // Technicien, maintenance
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(OPE_HEBERGEMENT)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  hotels         HotelUser[]
  bookings       Booking[]
  statusChanges  StatusHistory[]
  audits         RoomAudit[]
  mailLogs       MailLog[]

  // Quality relations
  ritualChecks   RitualCheck[]
  hotelAudits    HotelAudit[]

  resetToken        String?   @unique
  resetTokenExpires DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// HOTEL & ROOMS
// ============================================

model Hotel {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  phone     String?
  email     String?
  logo      String?
  rooms_count Int?
  rpsTarget Float?
  trustyouId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          HotelUser[]
  categories     RoomCategory[]
  rooms          Room[]
  bookings       Booking[]
  mailLogs       MailLog[]
  auditTemplates AuditTemplate[]

  // Quality relations
  monthlyPerfs       MonthlyPerf[]
  actionPlans        ActionPlan[]
  ritualChecks       RitualCheck[]
  roomEquipChecks    RoomEquipCheck[]
  commonAreaChecks   CommonAreaCheck[]
  maintenanceTickets MaintenanceTicket[]
  supplierMaints     SupplierMaint[]
  safetyItems        SafetyItem[]
  safetyCommissions  SafetyCommission[]
  hotelAudits        HotelAudit[]
  playbookCustoms    PlaybookCustom[]
}

model HotelUser {
  id      String @id @default(cuid())
  userId  String
  hotelId String
  role    Role   @default(OPE_HEBERGEMENT)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelId])
}

model RoomCategory {
  id          String   @id @default(cuid())
  hotelId     String
  name        String
  description String?
  price       Float
  capacity    Int      @default(2)
  amenities   String?
  photo       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rooms Room[]
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLEANING
  BLOCKED
}

model Room {
  id         String     @id @default(cuid())
  hotelId    String
  categoryId String
  number     String
  floor      Int        @default(1)
  status     RoomStatus @default(AVAILABLE)
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  hotel         Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  category      RoomCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  statusHistory StatusHistory[]
  audits        RoomAudit[]

  @@unique([hotelId, number])
}

model StatusHistory {
  id         String     @id @default(cuid())
  roomId     String
  fromStatus RoomStatus
  toStatus   RoomStatus
  changedBy  String
  notes      String?
  createdAt  DateTime   @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [changedBy], references: [id])
}

// ============================================
// BOOKINGS & GUESTS
// ============================================

model Guest {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  nationality String?
  idNumber    String?
  idDocument  String?
  company     String?
  companyVat  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

model Booking {
  id            String        @id @default(cuid())
  hotelId       String
  roomId        String
  guestId       String
  createdById   String
  checkIn       DateTime
  checkOut      DateTime
  nights        Int
  guests        Int           @default(1)
  status        BookingStatus @default(CONFIRMED)
  ratePerNight  Float
  discount      Float         @default(0)
  totalAmount   Float
  paymentMethod PaymentMethod @default(CASH)
  isPaid        Boolean       @default(false)

  breakfast     Boolean @default(false)
  parking       Boolean @default(false)
  babyBed       Boolean @default(false)
  transfer      Boolean @default(false)
  extras        String?

  includeTax    Boolean @default(true)
  taxRate       Float   @default(10)
  isProInvoice  Boolean @default(false)

  notes           String?
  specialRequests String?
  quickMode       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room      Room      @relation(fields: [roomId], references: [id])
  guest     Guest     @relation(fields: [guestId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
  payments  Payment[]
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String
  amount    Float
  method    PaymentMethod
  notes     String?
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ============================================
// MAILING
// ============================================

enum MailType {
  WELCOME
  BOOKING_CONFIRMATION
  REMINDER
  CHECKOUT
  INTERNAL_ALERT
  AUDIT_REPORT
  PASSWORD_RESET
}

model MailLog {
  id        String   @id @default(cuid())
  hotelId   String?
  userId    String?
  to        String
  subject   String
  type      MailType
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now())

  hotel Hotel? @relation(fields: [hotelId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])
}

// ============================================
// AUDIT / QUALITY CONTROL (RoomControl)
// ============================================

enum AuditScoringMode {
  BINARY
  SCORE
  COMMENT_ONLY
}

model AuditTemplate {
  id          String           @id @default(cuid())
  hotelId     String
  name        String
  description String?
  scoringMode AuditScoringMode @default(BINARY)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  hotel  Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  zones  AuditZone[]
  audits RoomAudit[]
}

model AuditZone {
  id         String   @id @default(cuid())
  templateId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  template    AuditTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  checkpoints AuditCheckpoint[]
}

model AuditCheckpoint {
  id          String   @id @default(cuid())
  zoneId      String
  label       String
  subCategory String?
  sortOrder   Int      @default(0)
  weight      Float    @default(1)
  isBlocking  Boolean  @default(false)
  createdAt   DateTime @default(now())

  zone    AuditZone               @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  results AuditCheckpointResult[]
}

model RoomAudit {
  id          String    @id @default(cuid())
  templateId  String
  roomId      String
  auditorId   String
  score       Float?
  maxScore    Float?
  passed      Boolean   @default(true)
  duration    Int?
  notes       String?
  signature   String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  template AuditTemplate           @relation(fields: [templateId], references: [id])
  room     Room                    @relation(fields: [roomId], references: [id])
  auditor  User                    @relation(fields: [auditorId], references: [id])
  results  AuditCheckpointResult[]
  photos   AuditPhoto[]
}

model AuditCheckpointResult {
  id           String   @id @default(cuid())
  auditId      String
  checkpointId String
  passed       Boolean?
  score        Int?
  comment      String?
  createdAt    DateTime @default(now())

  audit      RoomAudit       @relation(fields: [auditId], references: [id], onDelete: Cascade)
  checkpoint AuditCheckpoint @relation(fields: [checkpointId], references: [id])
}

model AuditPhoto {
  id                 String   @id @default(cuid())
  auditId            String
  url                String
  caption            String?
  checkpointResultId String?
  createdAt          DateTime @default(now())

  audit RoomAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

// ============================================
// somnOO QUALITY — PERFORMANCE (TrustYou)
// ============================================

model MonthlyPerf {
  id           String   @id @default(cuid())
  hotelId      String
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  year         Int
  month        Int      // 1-12
  rps          Float?
  rpsN1        Float?
  compIndex    Float?
  nbReviews    Int?
  responseRate Float?
  negImpact1   String?
  negImpact2   String?
  negImpact3   String?
  posImpact1   String?
  posImpact2   String?
  posImpact3   String?
  sparkles     Int?
  animations   Int?
  comments     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([hotelId, year, month])
}

// ============================================
// somnOO QUALITY — PLAN D'ACTION
// ============================================

enum ActionStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ActionCategory {
  CHAMBRE
  PROPRETE
  EQUIPEMENT
  MAINTENANCE
}

model ActionPlan {
  id       String         @id @default(cuid())
  hotelId  String
  hotel    Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  category ActionCategory
  score    Float?
  text     String
  dueDate  DateTime?
  owner    String
  status   ActionStatus   @default(TODO)
  budget   Float?
  comment  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ============================================
// somnOO QUALITY — RITUELS
// ============================================

model RitualCheck {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  ritualId  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  weekStart DateTime
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([hotelId, ritualId, weekStart])
}

// ============================================
// somnOO QUALITY — SUIVI TECHNIQUE CHAMBRES
// ============================================

enum EquipmentState {
  BON
  DEGRADE
  HS
}

model RoomEquipCheck {
  id          String       @id @default(cuid())
  hotelId     String
  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomNumber  String
  checkDate   DateTime
  equipStates Json         // { "TV": "BON", "Joints SDB": "DEGRADE", ... }
  action      String?
  status      ActionStatus @default(TODO)
  checkedBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ============================================
// somnOO QUALITY — SUIVI PARTIES COMMUNES
// ============================================

model CommonAreaCheck {
  id          String       @id @default(cuid())
  hotelId     String
  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  areaName    String
  checkDate   DateTime
  checkStates Json         // { "Peinture": "BON", "Sols": "DEGRADE" }
  action      String?
  status      ActionStatus @default(TODO)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ============================================
// somnOO QUALITY — MAINTENANCE QUOTIDIENNE
// ============================================

enum TicketPriority {
  HAUTE
  MOYENNE
  FAIBLE
}

enum TicketStatus {
  A_FAIRE
  EN_COURS
  TERMINE
}

model MaintenanceTicket {
  id         String         @id @default(cuid())
  hotelId    String
  hotel      Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  date       DateTime       @default(now())
  zone       String
  equipment  String
  problem    String
  priority   TicketPriority @default(MOYENNE)
  status     TicketStatus   @default(A_FAIRE)
  cost       Float?
  assignedTo String?
  photos     String[]
  comments   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

// ============================================
// somnOO QUALITY — MAINTENANCE FOURNISSEURS
// ============================================

model SupplierMaint {
  id        String    @id @default(cuid())
  hotelId   String
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  equipment String
  lastCheck DateTime?
  frequency String
  supplier  String?
  reserves  String?
  quotation Float?
  documents String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ============================================
// somnOO QUALITY — COMMISSION DE SÉCURITÉ
// ============================================

enum SafetyStatus {
  CONFORME
  RESERVE
  EN_COURS
  EXPIRE
}

model SafetyItem {
  id        String       @id @default(cuid())
  hotelId   String
  hotel     Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  category  String       // "moyens_secours", "controles", "formations"
  label     String
  lastCheck DateTime?
  frequency String
  status    SafetyStatus @default(EXPIRE)
  documents String[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model SafetyCommission {
  id            String    @id @default(cuid())
  hotelId       String
  hotel         Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  visitDate     DateTime
  result        String    // "favorable", "defavorable", "favorable_avec_reserves"
  prescriptions Json      // [{ text, resolved, resolvedDate }]
  nextVisitDate DateTime?
  pvDocument    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// somnOO QUALITY — AUDIT GLOBAL HÔTEL
// ============================================

model HotelAudit {
  id          String           @id @default(cuid())
  hotelId     String
  hotel       Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  auditDate   DateTime
  auditorId   String
  auditor     User             @relation(fields: [auditorId], references: [id])
  globalScore Float?
  items       HotelAuditItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model HotelAuditItem {
  id       String     @id @default(cuid())
  auditId  String
  audit    HotelAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  zone     String
  item     String
  score    Int        // 1-4
  comment  String?
  photos   String[]
}

// ============================================
// somnOO QUALITY — PLAYBOOK CUSTOM
// ============================================

model PlaybookCustom {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  type        String   // "event", "season_summer", "season_winter", "season_all", "boost"
  title       String
  description String?
  effort      String?  // "low", "med", "high"
  createdBy   String
  createdAt   DateTime @default(now())
}
